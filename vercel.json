{
  "rewrites": [
    { "source": "/", "destination": "/deto-homepage.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, x-admin-secret, x-reminder-secret, x-detailer-token" }
      ]
    }
  ]
}
